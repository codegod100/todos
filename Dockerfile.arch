FROM archlinux:latest

RUN pacman -Syu --noconfirm \
    qt6-base \
    qt6-declarative \
    qt6-tools \
    cmake \
    rust \
    cargo \
    gcc \
    make \
    git \
    ninja

RUN cargo install rust_qt_binding_generator

WORKDIR /build
COPY . .

RUN mkdir build_dir && cd build_dir && \
    export PATH=$PATH:$HOME/.cargo/bin && \
    cmake -GNinja .. && \
    ninja

# The binary will be in /build/build_dir/todos
